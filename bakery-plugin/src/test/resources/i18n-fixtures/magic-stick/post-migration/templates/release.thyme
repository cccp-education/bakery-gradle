<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<body>
    <div th:fragment="page">
        <div class="container py-4">
            <div class="row">
                <div class="col-lg-3 order-lg-1">
                    <div class="card mb-4 d-print-none">
                        <div class="card-body text-center">
                            <i class="bi bi-download display-4 text-primary"></i>
                            <h5 class="card-title mt-2" th:text="'v' + ${magicStickVersion}" th:if="${magicStickVersion}">v0.1.14</h5>
                            <p class="card-text" th:text="#{release.1}">Derniere version stable</p>
                            <a href="https://sourceforge.net/projects/magic-stick/files/" target="_blank" class="btn btn-primary w-100 mb-2">
                                <i class="bi bi-download me-1"></i>Telecharger
                            </a>
                            <a href="https://hub.docker.com/r/cccpeducation/magic-stick-cli" target="_blank" class="btn btn-outline-secondary w-100 mb-2">
                                <i class="bi bi-box me-1"></i>Docker CLI
                            </a>
                            <a href="https://github.com/cccp-education/magic-stick" target="_blank" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-github me-1"></i>GitHub
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-9 order-lg-0">
                    <article>
                        <header class="mb-4">
                            <h1 th:text="${content.title}">Notes de version</h1>
                        </header>
                        <div th:utext="${content.body}"></div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</body>
</html>