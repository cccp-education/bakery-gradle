<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:th="http://www.thymeleaf.org"
      data-bs-theme="light"
      lang="fr">

<head th:replace="header.thyme::head"/>

<body>
<div th:replace="menu.thyme::menu"/>

<main class="container py-5">
    <div class="row align-items-center mb-5" id="home">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold hero-title">Magic Stick</h1>
            <p class="lead" th:text="#{index.1}">Environnement portable standardise sur cle USB bootable.</p>
            <p th:text="#{index.2}">Formation, diagnostic reseau, dev nomade &mdash; partout, tout le temps, le meme outil.</p>
            <a class="btn btn-primary btn-lg me-2" href="#features" th:text="#{index.3}">Decouvrir</a>
            <a class="btn btn-success btn-lg" th:href="${content.rootpath + 'flash-guide.html'}">
                <i class="bi bi-usb-drive me-1"></i> Guide d'installation
            </a>
        </div>
        <div class="col-lg-6 text-center">
            <i class="bi bi-usb-drive" style="font-size:8rem;color:var(--bs-primary);"></i>
        </div>
    </div>

    <hr class="my-5"/>

    <div id="features">
        <h2 class="text-center mb-4" th:text="#{index.4}">Cas d'usage</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-mortarboard fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.5}">Formation</h5>
                        <p class="card-text" th:text="#{index.6}">Les apprenants ont tous la meme cle, prets a bosser des le 1er jour.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-wifi fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.7}">Diagnostic</h5>
                        <p class="card-text" th:text="#{index.8}">Technicien terrain : diagnostique reseau/FTTH quel que soit l'ordi.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-code-slash fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.9}">Dev nomade</h5>
                        <p class="card-text" th:text="#{index.10}">Retrouver sa stack complete sur n'importe quel PC.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-people fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.11}">Equipe technique</h5>
                        <p class="card-text" th:text="#{index.12}">Environnement standardise partage, pas de temps perdu en config.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5"/>

    <div id="architecture">
        <h2 class="text-center mb-4" th:text="#{index.13}">Architecture A/B</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-primary">
                    <div class="card-header bg-primary text-white">System A <small>(lecture seule)</small></div>
                    <div class="card-body">
                        <p>Systeme live Xubuntu actif (boote). ~8 Go.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-warning">
                    <div class="card-header bg-warning text-dark">System B <small>(lecture seule)</small></div>
                    <div class="card-body">
                        <p>Systeme live Xubuntu de secours (update atomique). ~8 Go.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-success">
                    <div class="card-header bg-success text-white">Persistence <small>(lecture/ecriture)</small></div>
                    <div class="card-body">
                        <p th:text="#{index.14}">Donnees utilisateur + config logiciels. Jamais touchee par les mises a jour systeme.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5"/>

    <div id="download" class="text-center py-5 mb-4 rounded-3" style="background: linear-gradient(135deg, var(--bs-primary), var(--bs-success));">
        <h2 class="text-white fw-bold">Telecharger Magic Stick</h2>
        <p class="text-white opacity-75 fs-5">ISO bootable Xubuntu 24.04 &mdash; BIOS + UEFI &mdash; 64 bits</p>
        <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
            <a class="btn btn-light btn-lg px-4 py-3 fw-semibold" href="https://sourceforge.net/projects/magic-stick/files/">
                <i class="bi bi-download me-2"></i>SourceForge <small>(ISO brute)</small>
            </a>
        </div>
        <p class="text-white opacity-50 mt-3">Clavier FR, locale fr_FR.UTF-8, autologin utilisateur <code>magic</code></p>
    </div>

    <hr class="my-5"/>

    <div id="docs">
        <h2 class="text-center mb-4" th:text="#{index.15}">Documentation</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-usb-drive fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.16}">Guide d'installation</h5>
                        <p class="card-text" th:text="#{index.17}">Telecharger l'ISO, flasher la cle USB avec balenaEtcher ou dd, booter.</p>
                        <a class="btn btn-outline-primary" th:href="${content.rootpath + 'flash-guide.html'}" th:text="#{index.18}">Installer</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-arrow-left-right fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.19}">Partition A/B</h5>
                        <p class="card-text" th:text="#{index.20}">Mise a jour atomique, rollback immediat, persistence des donnees.</p>
                        <a class="btn btn-outline-primary" th:href="${content.rootpath + 'ab-partition.html'}" th:text="#{index.21}">Comprendre</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-terminal fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.22}">Scripts</h5>
                        <p class="card-text" th:text="#{index.23}">Reference complete des commandes : build, flash, verify, update.</p>
                        <a class="btn btn-outline-primary" th:href="${content.rootpath + 'scripts.html'}" th:text="#{index.24}">Consulter</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <i class="bi bi-people fs-1 text-primary"></i>
                        <h5 class="card-title mt-3" th:text="#{index.25}">A propos</h5>
                        <p class="card-text" th:text="#{index.26}">Le projet, la licence, la philosophie A/B et la stack technique.</p>
                        <a class="btn btn-outline-primary" th:href="${content.rootpath + 'about.html'}" th:text="#{index.3}">Decouvrir</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<button id="scrollToTopBtn"
        class="btn btn-primary shadow-sm"
                th:attr="aria-label=#{index.28}" aria-label="Retour en haut de page">>
    <i class="bi bi-arrow-up"></i>
</button>

<div th:replace="footer.thyme::footer"/>
</body>
</html>