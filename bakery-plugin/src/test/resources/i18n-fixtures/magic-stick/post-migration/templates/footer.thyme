<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<body>
<div th:fragment="footer">
    <footer class="enhanced-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h5 class="fw-bold">
                        <i class="bi bi-usb-drive me-2"></i>
                        Magic Stick
                        <span class="badge bg-primary ms-1" th:text="'v' + ${magicStickVersion}" th:if="${magicStickVersion}">v0.1.14</span>
                    </h5>
                    <p class="footer-description">
                        Environnement portable standardise sur cle USB bootable.
                        Formation, diagnostic reseau, dev nomade.
                    </p>
                    <div class="social-icons">
                        <a href="https://github.com/cccp-education/magic-stick" target="_blank" aria-label="GitHub"><i class="bi bi-github"></i></a>
                        <a th:href="@{${content.rootpath} + 'feed.xml'}" aria-label="Flux RSS"><i class="bi bi-rss"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold" th:text="#{footer.1}">Documentation</h6>
                    <ul class="footer-links">
                        <li><a th:href="${content.rootpath} + 'flash-guide.html'"><i class="bi bi-chevron-right"></i>Guide d'installation</a></li>
                        <li><a th:href="${content.rootpath} + 'quick-start.html'"><i class="bi bi-chevron-right"></i>Demarrage rapide</a></li>
                        <li><a th:href="${content.rootpath} + 'ab-partition.html'"><i class="bi bi-chevron-right"></i>Partition A/B</a></li>
                        <li><a th:href="${content.rootpath} + 'scripts.html'"><i class="bi bi-chevron-right"></i>Scripts</a></li>
                        <li><a th:href="${content.rootpath} + 'releases.html'"><i class="bi bi-chevron-right"></i>Notes de version</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold" th:text="#{footer.2}">Telecharger</h6>
                    <ul class="footer-links">
                        <li><a href="https://sourceforge.net/projects/magic-stick/files/" target="_blank"><i class="bi bi-download"></i>SourceForge</a></li>
                        <li><a href="https://github.com/cccp-education/magic-stick" target="_blank"><i class="bi bi-github"></i>Code source</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold" th:text="#{footer.3}">Developpeur</h6>
                    <p class="mb-3">Projet developpe par cccp.education.</p>
                    <ul class="footer-links">
                        <li><a href="https://cccp.education" target="_blank"><i class="bi bi-globe"></i>cccp.education</a></li>
                        <li><a href="https://github.com/cccp-education" target="_blank"><i class="bi bi-github"></i>GitHub</a></li>
                    </ul>
                </div>
            </div>

            <hr class="footer-divider"/>
            <div class="footer-bottom">
                <p>&copy; 2024-<span th:text="${#dates.year(#dates.createNow())}"></span> cccp.education. Tous droits reserves.</p>
                <div class="footer-bottom-links">
                    <a href="https://cccp.education" target="_blank">cccp.education</a>
                    <a href="https://sourceforge.net/projects/magic-stick/" target="_blank">SourceForge</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
    <script th:src="@{${content.rootpath} + 'js/script.js'}"></script>
</div>
</body>
</html>