<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<body>
<div th:fragment="footer">
    <footer class="enhanced-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h5 class="fw-bold">
                        <i class="bi bi-person-workspace me-2"></i>
                        cheroliv.com
                    </h5>
                    <p class="footer-description">
                        Blog technique, articles et portfolio d'Olivier Chéron.
                    </p>
                    <div class="social-icons">
                        <a href="https://github.com/cheroliv" target="_blank" aria-label="GitHub"><i class="bi bi-github"></i></a>
                        <a th:href="@{${content.rootpath} + 'feed.xml'}" aria-label="Flux RSS"><i class="bi bi-rss"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold">Articles</h6>
                    <ul class="footer-links">
                        <li><a th:href="${content.rootpath} + 'kotlin.html'"><i class="bi bi-chevron-right"></i>Kotlin</a></li>
                        <li><a th:href="${content.rootpath} + 'gradle.html'"><i class="bi bi-chevron-right"></i>Gradle</a></li>
                        <li><a th:href="${content.rootpath} + 'ia.html'"><i class="bi bi-chevron-right"></i>IA</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold">Projets</h6>
                    <ul class="footer-links">
                        <li><a href="https://github.com/cccp-education" target="_blank"><i class="bi bi-chevron-right"></i>cccp.education</a></li>
                        <li><a href="https://github.com/cheroliv" target="_blank"><i class="bi bi-chevron-right"></i>GitHub perso</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold">Contact</h6>
                    <p class="mb-3">Pour échanger sur Kotlin, Gradle ou la formation.</p>
                    <ul class="footer-links">
                        <li><a href="mailto:contact@cheroliv.com"><i class="bi bi-envelope"></i>Email</a></li>
                        <li><a href="https://github.com/cheroliv" target="_blank"><i class="bi bi-github"></i>GitHub</a></li>
                    </ul>
                </div>
            </div>

            <hr class="footer-divider"/>
            <div class="footer-bottom">
                <p>&copy; 2024-<span th:text="${#dates.year(#dates.createNow())}"></span> Olivier Chéron. Tous droits réservés.</p>
                <div class="footer-bottom-links">
                    <a href="https://github.com/cheroliv" target="_blank">GitHub</a>
                </div>
            </div>
        </div>
    </footer>
</div>
</body>
</html>
