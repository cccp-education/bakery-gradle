                <!-- Location Section -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold" th:text="#{footer.10}">Localisation</h6>
                    <p class="mb-3" th:text="#{footer.11}">Basé en région parisienne, interventions possibles en France et à distance.</p>
                    <ul class="contact-info">
                        <li>
                            <i class="bi bi-geo-alt-fill"></i>
