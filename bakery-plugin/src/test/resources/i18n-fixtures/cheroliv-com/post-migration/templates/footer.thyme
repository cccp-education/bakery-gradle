            <!-- Footer Bottom -->
            <hr class="footer-divider">
            <div class="footer-bottom">
                <p>&copy; 2018-<span th:text="${#dates.year(#dates.createNow())}"></span> Cheroliv. Tous droits réservés.</p>
                <div class="footer-bottom-links">
                    <a href="#" th:text="#{footer.15}">Politique de confidentialité</a>
