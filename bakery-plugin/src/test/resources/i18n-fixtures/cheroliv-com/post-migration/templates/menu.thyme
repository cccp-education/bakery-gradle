                        </a></li>
                        <li><a class="dropdown-item lang-option" th:href="${content.rootpath + 'en/index.html'}" data-lang="en">
                            <i class="bi bi-flag me-2"></i>English
                        </a></li>
                        <li><a class="dropdown-item lang-option" th:href="${content.rootpath + 'ar/index.html'}" data-lang="ar">
