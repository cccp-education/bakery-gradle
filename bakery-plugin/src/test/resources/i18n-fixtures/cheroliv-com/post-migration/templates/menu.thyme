                        </a></li>
                        <li><a class="dropdown-item lang-option" th:href="${content.rootpath + 'pt/index.html'}" data-lang="pt">
                            <i class="bi bi-flag me-2"></i>Português
                        </a></li>
                        <li><a class="dropdown-item lang-option" th:href="${content.rootpath + 'ru/index.html'}" data-lang="ru">
                            <i class="bi bi-flag me-2"></i>Русский
