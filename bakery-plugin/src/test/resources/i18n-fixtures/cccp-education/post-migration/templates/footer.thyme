<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<body>
<div th:fragment="footer">
    <footer class="enhanced-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h5 class="fw-bold">
                        <i class="bi bi-hammer me-2"></i>
                        cccp.education
                    </h5>
                    <p class="footer-description">
                        Créateur de Contenus Commun Prolétaire. Briques logicielles libres pour créer du contenu.
                        Ecosysteme AsciiDoc, Gradle, Kotlin.
                    </p>
                    <div class="social-icons">
                        <a href="https://github.com/cccp-education" target="_blank" aria-label="GitHub"><i class="bi bi-github"></i></a>
                        <a th:href="@{${content.rootpath} + 'feed.xml'}" aria-label="Flux RSS"><i class="bi bi-rss"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold" th:text="#{footer.1}">Plugins</h6>
                    <ul class="footer-links">
                        <li><a th:href="${content.rootpath} + 'plugins.html'"><i class="bi bi-chevron-right"></i>Catalogue</a></li>
                        <li><a th:href="${content.rootpath} + 'about.html'"><i class="bi bi-chevron-right"></i>Licence Apache 2.0</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h6 class="fw-bold" th:text="#{footer.2}">Ressources</h6>
                    <ul class="footer-links">
                        <li><a href="https://github.com/cccp-education" target="_blank"><i class="bi bi-github"></i>GitHub org</a></li>
                        <li><a href="https://central.sonatype.com/namespace/education.cccp" target="_blank"><i class="bi bi-box-seam"></i>Maven Central</a></li>
                    </ul>
                </div>


            </div>

            <hr class="footer-divider"/>
            <div class="footer-bottom">
                <p>&copy; 2024-<span th:text="${#dates.year(#dates.createNow())}"></span> cccp.education. Licence Apache 2.0.</p>
                <div class="footer-bottom-links">
                    <a href="https://github.com/cccp-education" target="_blank">GitHub</a>
                    <a href="https://central.sonatype.com/namespace/education.cccp" target="_blank" th:text="#{footer.3}">Maven Central</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
    <script th:src="@{${content.rootpath} + 'js/script.js'}"></script>
</div>
</body>
</html>