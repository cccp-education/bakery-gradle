<!DOCTYPE html>
<html th:lang="${locale.language}" th:dir="${#sets.contains({'ar','ur'}, locale.language) ? 'rtl' : 'ltr'}" xmlns:th="http://www.thymeleaf.org">
<head th:include="header.thyme :: header">
    <title th:text="${content.title}">Page</title>
</head>
<body>
<div th:include="menu.thyme :: menu"></div>

<div class="container mt-5">
    <h1 th:text="${content.title}">Page title</h1>
    <div th:utext="${content.body} ?: #{page.title.fallback}">Contenu de la page</div>
</div>

<div th:include="footer.thyme :: footer"></div>
</body>
</html>
