<!DOCTYPE html>
<html th:lang="${locale.language}" th:dir="${#lists.contains({'ar','ur'}, locale.language) ? 'rtl' : 'ltr'}" xmlns:th="http://www.thymeleaf.org">
<head th:include="header.thyme :: header">
    <title th:text="#{nav.home}">Accueil</title>
</head>
<body>
<div th:include="menu.thyme :: menu"></div>

<div class="container mt-5">
    <div class="jumbotron bg-light p-5 rounded">
        <h1 class="display-4" th:text="${content.title} ?: #{index.welcome}">Bienvenue</h1>
        <p class="lead" th:if="${content.description}" th:text="${content.description} ?: #{index.description.fallback}">Description du site</p>
    </div>
    <div class="mt-4" th:utext="${content.body} ?: #{index.content.fallback}">Contenu principal</div>
</div>

<div th:include="footer.thyme :: footer"></div>
</body>
</html>
