<!DOCTYPE html>
<html th:lang="${locale.language}" xmlns:th="http://www.thymeleaf.org">
<head th:include="header.thyme :: header">
    <title>Accueil</title>
</head>
<body>
<div th:include="menu.thyme :: menu"></div>

<div class="container mt-5">
    <div class="jumbotron bg-light p-5 rounded">
        <h1 class="display-4" th:text="${content.title}">Bienvenue</h1>
        <p class="lead" th:if="${content.description}" th:text="${content.description}">Description du site</p>
    </div>
    <div class="mt-4" th:utext="${content.body}">Contenu principal</div>
</div>

<div th:include="footer.thyme :: footer"></div>
</body>
</html>
