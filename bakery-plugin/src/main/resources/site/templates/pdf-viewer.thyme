<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<!--/*-->
  PDF Viewer component — Embed PDF responsive dans une page JBake.
  Usage : <div th:replace="~{pdf-viewer.thyme::pdf-viewer}"/>
  Le PDF est injecté via jbake.properties (content.pdf ou metadata).
  Exemple : :jbake-pdf: pdfs/session-01.pdf
<!--*/-->
<div th:fragment="pdf-viewer" class="pdf-viewer-container mb-4"
     th:if="${content.pdf != null and content.pdf != ''}">
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        <i class="bi bi-file-earmark-pdf me-2"></i>Document PDF
      </h5>
      <a th:href="${content.rootpath} + ${content.pdf}"
         href="#" class="btn btn-sm btn-outline-primary" download>
        <i class="bi bi-download me-1"></i>Télécharger
      </a>
    </div>
    <div class="card-body p-0">
      <div class="pdf-viewer-responsive">
        <iframe th:src="${content.rootpath} + ${content.pdf}"
                class="pdf-viewer-iframe"
                title="Visualiseur PDF"
                loading="lazy">
        </iframe>
      </div>
    </div>
  </div>
  <style>
    .pdf-viewer-responsive {
      position: relative;
      width: 100%;
      padding-top: 75%; /* 4:3 ratio */
    }
    .pdf-viewer-iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    @media (max-width: 768px) {
      .pdf-viewer-responsive {
        padding-top: 100%; /* square on mobile */
      }
    }
  </style>
</div>
</html>