<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:th="http://www.thymeleaf.org"
      th:lang="${config.site_language}" th:dir="${#lists.contains({'ar','ur'}, config.site_language) ? 'rtl' : 'ltr'}" data-bs-theme="light">
<body>
<!-- =============================================================================================================== -->
<!-- Hero Section -->
<!-- =============================================================================================================== -->
<section id="home"
         class="hero-section"
         th:fragment="hero">
    <div id="main-content"></div>
    <div class="container">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="display-4 fw-bold mb-4">
                        <span th:text="#{hero.brand}">Bakery</span>
                        <span class="text-primary" th:text="#{hero.brand.sub}">Template</span>
                    </h1>
                    <p class="lead mb-4" th:text="#{hero.description}">
                        A simple and elegant space to share your knowledge, stories, and passions with the world..
                    </p>
                    <div class="hero-buttons d-grid d-lg-inline-flex gap-3">
                        <a href="https://github.com/cheroliv/bakery-gradle-plugin"
                           class="btn btn-primary btn-hero-style"
                           target="_blank"
                           rel="noopener noreferrer">
                            <i class="bi bi-rocket me-2"></i>
                            <span th:text="#{hero.button.project}">Project</span>
                        </a>
                        <a href="https://github.com/cheroliv/bakery-gradle-plugin/tree/main/site"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="btn btn-outline-primary btn-hero-style">
                            <i class="bi bi-envelope me-2"></i>
                            <span th:text="#{hero.button.template}">Template</span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image">
                    <div class="hero-card">
                        <div class="card-body text-center">
                            <i class="bi bi-laptop display-1 text-primary mb-3"></i>
                            <h3 th:text="#{hero.card.call.to.action}">Start Writing</h3>
                            <p th:text="#{hero.card.description}">Powered by the robustness of Bootstrap 5, this template offers you a seamless publishing experience and a fully responsive design, perfect for all your readers..</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
</body>
</html>
