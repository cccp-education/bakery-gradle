<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org" th:lang="${config.site_language}" th:dir="${#lists.contains({'ar','ur'}, config.site_language) ? 'rtl' : 'ltr'}">
	<head th:replace="header.thyme::head"/>
	<body onload="prettyPrint()">
	<div id="wrap">
		<div th:replace="menu.thyme::menu"/>
		<div th:replace="~{progress-bar.thyme::progress-bar}"/>
		<div th:replace="~{breadcrumb.thyme::breadcrumb}"/>
		<div class="container">
	
			<div th:replace="~{layout-full-width.thyme::layout-full-width}">
				<div th:replace="~{layout-sidebar-left.thyme::layout-sidebar-left}">
					<div th:replace="~{layout-sidebar-right.thyme::layout-sidebar-right}">
						<div th:replace="~{layout-centered.thyme::layout-centered}">
							<div class="page-header">
								<h1 th:text='${content.title}'>title</h1>
							</div>
						
							<p><em th:text='${#dates.format(content.date,"dd MMMM yyyy")}'>date</em></p>

							<div th:replace="~{pdf-viewer.thyme::pdf-viewer}"/>
						
							<p th:utext='${content.body}'>body</p>

							<div th:replace="~{google-forms.thyme::google-forms}"/>
							<div th:replace="~{augmented-articles.thyme::augmented-articles}"/>
							<div th:replace="~{comments.thyme::comments}"/>
						</div>
					</div>
				</div>
			</div>
		
			<hr />
		</div>
	</div>
	<div th:replace="footer.thyme::footer"></div>
    </body>
</html>