<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<!--/*-->
  TOC Sidebar component — Table des matières extraite côté client.
  Usage : <div th:replace="~{toc-sidebar.thyme::toc-sidebar}"/>
  Le JavaScript extrait les headings h2/h3 du contenu principal.
<!--*/-->
<aside th:fragment="toc-sidebar" class="toc-sidebar card mb-4">
  <div class="card-header">
    <h5 class="mb-0">
      <i class="bi bi-list-ul me-2"></i>Sommaire
    </h5>
  </div>
  <nav class="card-body p-3">
    <ul id="toc-list" class="nav flex-column"></ul>
  </nav>
  <script th:inline="javascript">
    /*<![CDATA[*/
    (function() {
      var content = document.querySelector('.content') || document.querySelector('main');
      if (!content) return;
      var headings = content.querySelectorAll('h2, h3');
      var tocList = document.getElementById('toc-list');
      if (!tocList || headings.length === 0) return;
      headings.forEach(function(heading) {
        if (!heading.id) {
          heading.id = heading.textContent
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/(^-|-$)/g, '');
        }
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + heading.id;
        a.textContent = heading.textContent;
        a.className = 'nav-link' + (heading.tagName === 'H3' ? ' ms-3' : '');
        li.appendChild(a);
        tocList.appendChild(li);
      });
    })();
    /*]]>*/
  </script>
  <style>
    .toc-sidebar .nav-link {
      font-size: 0.875rem;
      color: var(--bs-secondary);
      padding: 0.25rem 0.5rem;
    }
    .toc-sidebar .nav-link:hover {
      color: var(--bs-primary);
    }
  </style>
</aside>
</html>