<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<!--/*
  Related Articles component — Display knowledge graph suggestions for the current article.
  Usage : <div th:replace="~{related-articles.thyme::related-articles}"/>
  The section is shown only when relatedArticlesEnabled=true (injected via jbake.properties).
  Suggestions are resolved from relatedArticlesData JSON (injected via jbake.properties)
  and filtered by the current page URI (content.uri).
*/-->
<aside th:fragment="related-articles" class="related-articles mt-4"
        th:if="${relatedArticlesEnabled != null && relatedArticlesEnabled == 'true'}"
        th:data-related-articles="${relatedArticlesData}"
        th:data-max-results="${relatedArticlesMaxResults}">
  <h3 class="related-articles-heading" th:text="${relatedArticlesHeading != null ? relatedArticlesHeading : 'Articles connexes'}">Articles connexes</h3>
  <ul class="related-articles-list" id="related-articles-list">
    <!-- Populated by JavaScript from relatedArticlesData JSON -->
  </ul>
  <script th:inline="javascript">
    /*<![CDATA[*/
    (function() {
      var aside = document.currentScript.closest('aside.related-articles');
      if (!aside || !aside.dataset.relatedArticles) return;
      try {
        var data = JSON.parse(aside.dataset.relatedArticles);
        var currentUri = /*[[${content != null ? content.uri : ''}]]*/ '';
        var suggestions = data.suggestions || {};
        var blogArticles = data.blogArticles || {};
        var maxResults = parseInt(aside.dataset.maxResults || '4', 10);
        var related = suggestions[currentUri] || [];
        var list = document.getElementById('related-articles-list');
        if (!list) return;
        related.slice(0, maxResults).forEach(function(s) {
          var li = document.createElement('li');
          var a = document.createElement('a');
          a.href = s.url;
          a.textContent = s.title;
          li.appendChild(a);
          list.appendChild(li);
        });
        if (related.length === 0) {
          aside.style.display = 'none';
        }
      } catch(e) {
        if (aside) aside.style.display = 'none';
      }
    })();
    /*]]>*/
  </script>
</aside>