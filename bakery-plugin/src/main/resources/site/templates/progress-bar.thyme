<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<!--/*-->
  Progress Bar component — Barre de progression de lecture (scroll).
  Usage : <div th:replace="~{progress-bar.thyme::progress-bar}"/>
  Se place en haut de la page. CSS sticky + JS scroll event.
<!--*/-->
<div th:fragment="progress-bar" class="reading-progress-wrapper">
  <div id="reading-progress-bar" class="reading-progress-bar" role="progressbar"
       aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" th:attr="aria-label=#{progress.bar.label}" aria-label="Progression de lecture">
  </div>
  <script th:inline="javascript">
    /*<![CDATA[*/
    (function() {
      var bar = document.getElementById('reading-progress-bar');
      if (!bar) return;
      function updateProgress() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = Math.min(progress, 100) + '%';
        bar.setAttribute('aria-valuenow', Math.round(progress));
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      document.addEventListener('DOMContentLoaded', updateProgress);
    })();
    /*]]>*/
  </script>
  <style>
    .reading-progress-wrapper {
      position: sticky;
      top: 0;
      z-index: 1030;
      width: 100%;
      height: 3px;
      background: transparent;
    }
    .reading-progress-bar {
      height: 3px;
      width: 0%;
      background: var(--bs-primary);
      transition: width 0.1s linear;
    }
  </style>
</div>
</html>