<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">
<body>
<!-- =============================================================================================================== -->
<!-- Theme Script Fragment — BKY-JB-6 + BKY-IA-2 -->
<!-- Injects CSS custom properties (variables) from theme config into :root -->
<!-- Supports variant presets (magazine, documentation, etc.) with individual overrides -->
<!-- =============================================================================================================== -->
<div th:fragment="theme-script" th:if="${themePrimaryColor}">
    <script th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-primary', /*[[${themePrimaryColor}]]*/ '#0d6efd');
        document.documentElement.style.setProperty('--bakery-secondary', /*[[${themeSecondaryColor}]]*/ '#6c757d');
        /*<!-- BKY-IA-2: Extended theme variables -->*/
    </script>
    <script th:if="${themeAccentColor}" th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-accent', /*[[${themeAccentColor}]]*/ '');
    </script>
    <script th:if="${themeBackgroundColor}" th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-bg', /*[[${themeBackgroundColor}]]*/ '#ffffff');
    </script>
    <script th:if="${themeTextColor}" th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-text', /*[[${themeTextColor}]]*/ '#333333');
    </script>
    <script th:if="${themeFontFamily}" th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-font-family', /*[[${themeFontFamily}]]*/ 'system-ui, sans-serif');
        document.body.style.fontFamily = /*[[${themeFontFamily}]]*/ 'system-ui, sans-serif';
    </script>
    <script th:if="${themeHeadingFont}" th:inline="javascript">
        document.documentElement.style.setProperty('--bakery-heading-font', /*[[${themeHeadingFont}]]*/ '');
        document.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach(function(el) {
            el.style.fontFamily = /*[[${themeHeadingFont}]]*/ '';
        });
    </script>
</div>
</body>
</html>