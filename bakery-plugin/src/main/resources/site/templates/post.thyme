<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org" th:lang="${config.site_language}" th:dir="${#sets.contains({'ar','ur'}, config.site_language) ? 'rtl' : 'ltr'}">
<head th:replace="~{header.thyme::head}"/>
<body>
<div class="main-content-wrapper">
    <div th:replace="~{menu.thyme::menu}"/>
    <main class="main-content-padding" id="main-content">
        <div th:replace="~{progress-bar.thyme::progress-bar}"/>
        <div th:replace="~{breadcrumb.thyme::breadcrumb}"/>
        <div th:replace="~{layout-full-width.thyme::layout-full-width}">
            <div th:replace="~{layout-sidebar-left.thyme::layout-sidebar-left}">
                <div th:replace="~{layout-sidebar-right.thyme::layout-sidebar-right}">
                    <div th:replace="~{layout-centered.thyme::layout-centered}">
                        <div class="row">
                            <div class="col-lg-9">
                                <article>
                                    <header class="page-header mb-4">
                                        <h1 class="h2" th:text="${content.title}">Titre de l'article</h1>
                                        <p class="lead">
                                            <em th:text="#{label.published.on} + ${#dates.format(content.date, 'dd MMMM yyyy')}">Date de publication</em>
                                        </p>
                                    </header>

                                    <div class="content" th:utext="${content.body}">
                                        Contenu de l'article...
                                    </div>

                                    <div th:replace="~{comments.thyme::comments}"/>

                                    <div th:replace="~{augmented-articles.thyme::augmented-articles}"/>

                                </article>
                            </div>
                            <div class="col-lg-3 d-none d-lg-block">
                                <div th:replace="~{toc-sidebar.thyme::toc-sidebar}"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div th:replace="~{footer.thyme::footer}"></div>
</body>
</html>
